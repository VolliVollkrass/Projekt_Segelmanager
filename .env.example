# Kopiere diese Datei als .env und fülle die Werte aus
# Niemals die echte .env committen!

# Django
SECRET_KEY=hier_einen_langen_zufaelligen_key_eintragen
DEBUG=False
ALLOWED_HOSTS=segelmanager.undmeererleben.de
CSRF_TRUSTED_ORIGINS=https://segelmanager.undmeererleben.de

# Datenbank (PostgreSQL auf Hetzner)
DATABASE_URL=postgres://segelmanager_user:PASSWORT@postgres/segelmanager

# E-Mail (Brevo)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=deine@email.de
EMAIL_HOST_PASSWORD=brevo_smtp_key_hier
DEFAULT_FROM_EMAIL=Meer erleben <info@undmeererleben.de>
